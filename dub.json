{
    "name": "gs",
    "description": "GScript3",
    "homepage": "",
    "license": "Boost",
    "authors": [
        "Timur Gafarov"
    ],
    "dependencies": {
        "dlib": "~>1.4.1"
    },
    "targetType": "library",
    "sourcePaths": ["src"],
    "importPaths": ["src"],
    "subPackages": [
        {
            "name": "gscript",
            "targetType": "executable",
