            "importPaths": ["src", "toolsgscript"],
            "mainSourceFile": "tools/gscript/main.d",
            "buildRequirements":[
                "allowWarnings"
            ]
        },
        {
            "name": "gsrunner",
            "targetType": "executable",
            "targetName": "gsrunner",
            "dependencies": {
                "dlib": "~>1.4.1"
            },
            "sourcePaths": ["src", "tools/gsrunner"],
            "importPaths": ["src", "tools/gsrunner"],
            "mainSourceFile": "tools/gsrunner/main.d",
            "buildRequirements":[
                "allowWarnings"
            ]
        }
    ]
}
